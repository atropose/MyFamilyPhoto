[Unit]
Description=MyPicManager Backend (FastAPI)
After=network.target

[Service]
Type=simple
User=atropose
WorkingDirectory=/home/atropose/FamilyPhoto/backend
ExecStart=/home/atropose/FamilyPhoto/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
EnvironmentFile=/home/atropose/FamilyPhoto/backend/.env

[Install]
WantedBy=multi-user.target
