# MyPicManager 백엔드 환경 변수
# 이 파일을 .env 로 복사한 후 값을 수정하세요

# 미디어 파일 루트 경로 (Linux 예시)
MEDIA_ROOT=/mnt/photos

# 썸네일 캐시 경로 (기본: ./thumbnails)
THUMBNAILS_DIR=./thumbnails

# SQLite DB 경로 (기본: ./mypicmanager.db)
DB_PATH=./mypicmanager.db

# Windows AI 서비스 URL (얼굴 감지, 사용 안 할 경우 비워둠)
AI_SERVICE_URL=http://192.168.1.100:8100

# 기본 패스코드 (DB에 저장되므로 최초 1회만 적용)
DEFAULT_PASSCODE=1234
